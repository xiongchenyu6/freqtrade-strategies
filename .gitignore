# Secrets - NEVER commit plaintext
secrets.yaml.plaintext
*.plaintext
*.pem
*.key
.env
.env.*
!.env.example

# Plaintext / scratch copies of sops files
secrets.env.tmp
secrets.env.new
secrets.env.bak
secrets.env.local
secrets.yaml.tmp
secrets.yaml.bak
*.sops.tmp
*.tmp

# Legacy / large artifacts (anchored to repo root so similarly-named
# directories under web/apps/app/{static,src/routes}/reports/ stay tracked).
/configs_legacy/
/models/
/hyperopt_results/
/user_data/
/freqaimodels/
/notebooks/
/data_bulk/
/reports/

# Bulky generated HTML in static/reports/ (Plotly inline ~5–25MB each).
# The manifest.json is small and IS tracked so SSR can resolve folder names
# at build time; the actual reports are regenerated by visualize_strategy.py.
web/apps/app/static/reports/**/*.html
web/apps/app/static/reports/**/*.js
!web/apps/app/static/reports/manifest.json

# Data
data/
sentiment_data/
*.sqlite
*.sqlite-wal
*.sqlite-shm
backtest_results/

# Local state
risk_state.json

# Logs
logs/
*.log

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# System
.direnv/
.DS_Store
