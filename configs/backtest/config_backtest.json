{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "trading_mode": "spot",
    "margin_mode": "",
    "max_open_trades": 5,
    "stake_currency": "USDT",
    "stake_amount": "unlimited",
    "tradable_balance_ratio": 0.95,
    "fiat_display_currency": "USD",
    "timeframe": "1d",
    "dry_run": true,
    "dry_run_wallet": 10000,
    "trading_fees": {
        "entry": 0.001,
        "exit": 0.001
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "BTC/USDT",
            "ETH/USDT",
            "BNB/USDT",
            "SOL/USDT",
            "DOGE/USDT",
            "AVAX/USDT",
            "DOT/USDT",
            "LINK/USDT",
            "ADA/USDT",
            "FIL/USDT",
            "APT/USDT",
            "ARB/USDT",
            "OP/USDT",
            "INJ/USDT",
            "XRP/USDT"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {"method": "StaticPairList"}
    ],
    "dataformat_ohlcv": "feather",
    "dataformat_trades": "feather"
}
