{
    "$schema": "https://schema.freqtrade.io/schema.json",
    "trading_mode": "spot",
    "margin_mode": "",
    "max_open_trades": 3,
    "stake_currency": "USDT",
    "stake_amount": 1500,
    "tradable_balance_ratio": 0.95,
    "available_capital": 10000,
    "fiat_display_currency": "USD",
    "timeframe": "1m",
    "dry_run": true,
    "dry_run_wallet": 10000,
    "cancel_open_orders_on_exit": true,
    "unfilledtimeout": {
        "entry": 5,
        "exit": 5,
        "exit_timeout_count": 0,
        "unit": "minutes"
    },
    "entry_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1,
        "price_last_balance": 0.0,
        "check_depth_of_market": {
            "enabled": false,
            "bids_to_ask_delta": 1
        }
    },
    "exit_pricing": {
        "price_side": "same",
        "use_order_book": true,
        "order_book_top": 1
    },
    "exchange": {
        "name": "binance",
        "key": "",
        "secret": "",
        "ccxt_config": {},
        "ccxt_async_config": {},
        "pair_whitelist": [
            "ETH/USDT",
            "BNB/USDT",
            "SOL/USDT"
        ],
        "pair_blacklist": []
    },
    "pairlists": [
        {
            "method": "StaticPairList"
        }
    ],
    "trading_fees": {
        "entry": 0.001,
        "exit": 0.001
    },
    "telegram": {
        "enabled": false,
        "token": "",
        "chat_id": "",
        "_note": "Disabled: 15mDry bot already holds the Telegram polling channel. MTF state changes still reach Telegram via risk_monitor.py sendMessage."
    },
    "api_server": {
        "enabled": true,
        "listen_ip_address": "127.0.0.1",
        "listen_port": 8083,
        "verbosity": "error",
        "jwt_secret_key": "",
        "CORS_origins": [
            "http://localhost:3000",
            "http://localhost:3001",
            "http://127.0.0.1:3001"
        ],
        "username": "",
        "password": ""
    },
    "bot_name": "HonestTrend1mMTF-DRYRUN",
    "strategy": "HonestTrend1mMTF",
    "initial_state": "running",
    "force_entry_enable": false,
    "internals": {
        "process_throttle_secs": 5
    },
    "dataformat_ohlcv": "feather",
    "dataformat_trades": "feather",
    "position_adjustment_enable": true,
    "max_entry_position_adjustment": 2
}