# Template for secrets.env — copy to secrets.env and encrypt with SOPS:
#   cp secrets.env.example secrets.env
#   sops encrypt -i secrets.env
#
# After encryption, edit via: sops secrets.env
#
# All values are optional — only set what you use.

# --- Supabase (PostgreSQL data layer) ---
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_KEY=<anon-publishable-key>
SUPABASE_SECRET=<service-role-key>
SUPABASE_DB_PASSWORD=<db-password>
SUPABASE_MGMT_TOKEN=sbp_<personal-access-token>

# --- Telegram (alerts + daily reports) ---
TELEGRAM_BOT_TOKEN=<from-@BotFather>
TELEGRAM_CHAT_ID=<your-chat-id>

# --- Binance (LIVE TRADING ONLY — leave empty for dry-run) ---
# Permissions: Spot Trading ON, Withdrawals OFF, IP whitelist REQUIRED
BINANCE_API_KEY=
BINANCE_API_SECRET=

# --- Zyte Scrapy Cloud (optional scraping) ---
ZYTE_API_KEY=
ZYTE_PROJECT_ID=

# --- Deepnote (optional notebook execution) ---
DEEPNOTE_API_KEY=
DEEPNOTE_PROJECT_ID=
DEEPNOTE_NOTEBOOK_ID=

# --- Anthropic (optional LLM-enhanced sentiment) ---
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_API_KEY=

# --- Santiment (optional on-chain metrics) ---
SANTIMENT_API_KEY=

# --- Freqtrade REST API (for telegram_alerts.py scraping bot P&L) ---
FREQTRADE_API_USER=freqtrader
FREQTRADE_API_PASSWORD=<set-matching-your-freqtrade-config>
